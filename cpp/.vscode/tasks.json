{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: Build active file",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}/bin/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Compiles the active file with g++ (C++17) into bin/",
      "dependsOn": "Create bin dir"
    },
    {
      "label": "Create bin dir",
      "type": "shell",
      "command": "mkdir",
      "args": ["-p", "${workspaceFolder}/bin"],
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": []
    },
    {
      "label": "C++: Build & Run active file",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}/bin/${fileBasenameNoExtension}",
        "&&",
        "${workspaceFolder}/bin/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/bash",
          "args": ["-c"]
        }
      },
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Compiles and immediately runs the active file",
      "dependsOn": "Create bin dir"
    }
  ]
}
